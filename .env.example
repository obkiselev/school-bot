# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here

# Encryption Key (Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your_fernet_encryption_key_here

# Database
DATABASE_PATH=data/school_bot.db

# Logging
LOG_LEVEL=INFO

# МЭШ API Settings (URL управляются библиотекой OctoDiary)
MESH_TIMEOUT=30
MESH_MAX_RETRIES=3

# Notification Settings
GRADES_NOTIFICATION_TIME=18:00
HOMEWORK_NOTIFICATION_TIME=19:00
REMINDER_NOTIFICATION_TIME=20:00
TIMEZONE=Europe/Moscow

# Browser Auth (Playwright/Patchright)
MESH_AUTH_HEADLESS=true
MESH_AUTH_STEALTH=true

# Proxy for МЭШ authentication (optional, if IP is blocked)
# MESH_PROXY_URL=socks5://127.0.0.1:1080

# SSH tunnel — auto-start SOCKS5 proxy on bot startup (only for local dev)
# Disabled by default — bot runs on server directly since v0.6.1
# MESH_SSH_PROXY=true
# MESH_SSH_HOST=45.152.113.91
# MESH_SSH_PORT=4422
# MESH_SSH_USER=life_sync
# MESH_SSH_KEY=~/.ssh/id_ed25519_rag
# MESH_SSH_PATH=

# Rate Limiting
API_MAX_CALLS=30
API_PERIOD_SECONDS=60

# LLM (тестирование по языкам — LM Studio)
LLM_CONNECT_MODE=local
LLM_BASE_URL=http://localhost:1234/v1
# Optional hybrid mode (v1.2.1): server -> remote LLM host
# LLM_REMOTE_BASE_URL=https://your-llm-host.example.com/v1
# LLM_REMOTE_API_KEY=your_remote_api_key
# LLM_REQUEST_TIMEOUT=45
LLM_MODEL=qwen2.5-7b-instruct
QUIZ_TEMPLATE_FALLBACK_ENABLED=true

# Access Control — Telegram ID главного администратора
ADMIN_ID=
